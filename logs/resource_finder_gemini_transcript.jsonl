{"type":"tool_use","timestamp":"2026-06-07T21:10:58.009Z","tool_name":"write_file","tool_id":"write_file__write_file_1780866658008_0","parameters":{"file_path":"download_papers.py","content":"import arxiv\nimport requests\nimport os\n\ndef download_paper(query, filename):\n    client = arxiv.Client()\n    search = arxiv.Search(query=f'title:\"{query}\"', max_results=1)\n    results = list(client.results(search))\n    if not results:\n        # Try without title: prefix\n        search = arxiv.Search(query=query, max_results=1)\n        results = list(client.results(search))\n        \n    if results:\n        paper = results[0]\n        print(f\"Found: {paper.title}\")\n        print(f\"URL: {paper.pdf_url}\")\n        r = requests.get(paper.pdf_url)\n        with open(os.path.join('papers', filename), 'wb') as f:\n            f.write(r.content)\n        print(f\"Downloaded {filename}\")\n    else:\n        print(f\"No results for {query}\")\n\nos.makedirs('papers', exist_ok=True)\ndownload_paper('Scaling deep learning for materials discovery', '2023_Merchant_GNoME.pdf')\ndownload_paper('Automating alloy design and discovery with physics-aware multimodal multiagent AI', '2025_Buehler_Alloy_AI.pdf')\ndownload_paper('Active Learning for Conditional Inverse Design with Crystal Generation and Foundation Atomic Models', '2025_Li_Active_Learning_FAM.pdf')\n"}}
